[project]
name = "AI4Careers"
version = "0.1.0"
description = "AI-powered career fair assistant"
entry-point = "main.jac"

[dependencies]

[serve]

[plugins.scale.secrets]
OPENAI_API_KEY="${OPENAI_API_KEY}"

[plugins.client]

# --- Choose your model ---
# OpenAI (set OPENAI_API_KEY in your environment):
#   default_model = "gpt-4o-mini"
# Anthropic (set ANTHROPIC_API_KEY in your environment):
#   default_model = "claude-haiku-4-5-20251001"
[plugins.byllm.model]
default_model = "gpt-4o-mini"

[plugins.byllm.visual]
openai_model = "gpt-5.4-nano"
anthropic_model = "claude-3-5-haiku-20241022"

[plugins.byllm.call_params]
temperature = 0.2

[plugins.byllm]
system_prompt = "You are a helpful AI career fair assistant. Be concise, practical, and grounded in the available resume and company data."
